generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id          String   @id @default(cuid())
  title       String
  description String
  posterUrl   String
  backdropUrl String?
  genre       String
  language    String
  duration    Int
  rating      Float
  releaseDate DateTime
  trailerUrl  String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
